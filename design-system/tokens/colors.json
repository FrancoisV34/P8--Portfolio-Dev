{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "primitive": {
      "gray": {
        "0":   { "$value": "oklch(1 0 0)",       "$type": "color" },
        "50":  { "$value": "oklch(0.99 0 0)",    "$type": "color" },
        "100": { "$value": "oklch(0.97 0 0)",    "$type": "color" },
        "200": { "$value": "oklch(0.92 0 0)",    "$type": "color" },
        "300": { "$value": "oklch(0.85 0 0)",    "$type": "color" },
        "400": { "$value": "oklch(0.65 0 0)",    "$type": "color" },
        "500": { "$value": "oklch(0.50 0 0)",    "$type": "color" },
        "600": { "$value": "oklch(0.35 0 0)",    "$type": "color" },
        "700": { "$value": "oklch(0.25 0 0)",    "$type": "color" },
        "800": { "$value": "oklch(0.18 0 0)",    "$type": "color" },
        "900": { "$value": "oklch(0.14 0 0)",    "$type": "color" },
        "950": { "$value": "oklch(0.07 0 0)",    "$type": "color" },
        "1000":{ "$value": "oklch(0 0 0)",       "$type": "color" }
      },
      "graphite": {
        "300": { "$value": "oklch(0.85 0.02 260)", "$type": "color" },
        "500": { "$value": "oklch(0.50 0.02 260)", "$type": "color" },
        "700": { "$value": "oklch(0.30 0.02 260)", "$type": "color" },
        "900": { "$value": "oklch(0.18 0.02 260)", "$type": "color" }
      },
      "red":    { "600": { "$value": "oklch(0.58 0.23 27)",  "$type": "color" } },
      "green":  { "600": { "$value": "oklch(0.62 0.17 150)", "$type": "color" } },
      "amber":  { "500": { "$value": "oklch(0.78 0.16 80)",  "$type": "color" } }
    },
    "semantic": {
      "light": {
        "background":          { "$value": "{color.primitive.gray.50}",  "$type": "color" },
        "surface":             { "$value": "{color.primitive.gray.100}", "$type": "color" },
        "surface-elevated":    { "$value": "{color.primitive.gray.0}",   "$type": "color" },
        "border":              { "$value": "{color.primitive.gray.200}", "$type": "color" },
        "foreground":          { "$value": "{color.primitive.gray.900}", "$type": "color" },
        "foreground-muted":    { "$value": "{color.primitive.gray.500}", "$type": "color" },
        "accent":              { "$value": "{color.primitive.graphite.700}", "$type": "color" },
        "accent-foreground":   { "$value": "{color.primitive.gray.0}",       "$type": "color" },
        "success":             { "$value": "{color.primitive.green.600}",    "$type": "color" },
        "warning":             { "$value": "{color.primitive.amber.500}",    "$type": "color" },
        "destructive":         { "$value": "{color.primitive.red.600}",      "$type": "color" }
      },
      "dark": {
        "background":          { "$value": "{color.primitive.gray.1000}","$type": "color" },
        "surface":             { "$value": "{color.primitive.gray.900}", "$type": "color" },
        "surface-elevated":    { "$value": "{color.primitive.gray.800}", "$type": "color" },
        "border":              { "$value": "{color.primitive.gray.700}", "$type": "color" },
        "foreground":          { "$value": "{color.primitive.gray.100}", "$type": "color" },
        "foreground-muted":    { "$value": "{color.primitive.gray.400}", "$type": "color" },
        "accent":              { "$value": "{color.primitive.graphite.300}", "$type": "color" },
        "accent-foreground":   { "$value": "{color.primitive.gray.900}",     "$type": "color" },
        "success":             { "$value": "{color.primitive.green.600}","$type": "color" },
        "warning":             { "$value": "{color.primitive.amber.500}","$type": "color" },
        "destructive":         { "$value": "{color.primitive.red.600}",  "$type": "color" }
      }
    }
  }
}
